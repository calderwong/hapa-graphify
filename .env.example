# Hapa Graphify local source configuration.
# Copy values into your shell/profile or a private .env file. Do not commit .env.

HAPA_GRAPHIFY_HOST=127.0.0.1
HAPA_GRAPHIFY_PORT=8796
HAPA_GRAPHIFY_SOURCE_REGISTRY=config/hapa-graphify.sources.json

# Source roots. Use absolute paths on your machine.
HAPA_SECOND_BRAIN_DB=/path/to/hapa_second_brain.db
HAPA_FRONT_DOOR_DOCS=/path/to/hapa/docs
HAPA_WIKI_ROOT=/path/to/Hapa_Worldbuilding_Wiki
HAPA_WIKI_OPERATIONS_ROOT=/path/to/Hapa_Worldbuilding_Wiki/Operations
HAPA_OVERWATCH_ROOT=/path/to/hapa-overwatch-kanban
HAPA_OVERWATCH_CONFIG_DIR=/path/to/hapa-overwatch-kanban/config/projects
HAPA_QUEST_KEEPER_AUDIT=/path/to/hapa-quest-keeper/artifacts/audit/hapa-node-kanban-audit.json
HAPA_QUEST_KEEPER_AUDIT_ROOT=/path/to/hapa-quest-keeper/artifacts/audit
HAPA_NODE_MAP=/path/to/hapa/docs/NODE_MAP.md
